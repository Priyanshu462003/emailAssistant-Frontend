{
    "name": "Email Assistant",
    "description": "AI-powered email assistant",
    "version": "1.0",
    "manifest_version": 3,
    "permissions": [
        "activeTab",
        "storage",
        "identity",
        "notifications"
    ],
    "oauth2": {
        "client_id": "307538430828-ikofb96o0fut9rpprjvdom8b7qdbnb8l.apps.googleusercontent.com",
        "scopes": [
            "https://www.googleapis.com/auth/calendar.events"
        ]
    },
    "host_permissions": [
        "http://localhost:8080/*",
        "*://mail.google.com/*"
    ],
    "content_scripts": [
        {
            "js": ["content.js"],
            "matches": ["*://mail.google.com/*"],
            "css": ["content.css"],
            "run_at": "document_end"
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "web_accessible_resources": [
        {
            "resources": ["icons/*"],
            "matches": ["*://mail.google.com/*"]
        }
    ],
    "action": {
        "default_title": "Email Assistant"
    }
}